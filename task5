#Script to read groups.txt file and create groups with gids
#!/bin/bash
while IFS=":" read group gid;
do
        groupadd -g $gid $group;
done < groups.txt

#sctipt to create the users 
#!/bin/bash
while IFS=":" read user uid groups;
do
 useradd -G $groups -u $uid $user;
done < users.txt


